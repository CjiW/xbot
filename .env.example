# ============================================================================
# xbot 配置
# 复制此文件为 .env 并填写实际值
# ============================================================================

# --- LLM 配置 ---
# 提供商: "openai" 或 "codebuddy"
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your-api-key
LLM_MODEL=deepseek-chat

# CodeBuddy 专用配置（如果 LLM_PROVIDER=codebuddy）
# LLM_USER_ID=
# LLM_ENTERPRISE_ID=
# LLM_DOMAIN=

# --- 飞书渠道 ---
FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 可选：事件加密和验证
# FEISHU_ENCRYPT_KEY=
# FEISHU_VERIFICATION_TOKEN=
# 可选：允许的用户 open_id 列表（逗号分隔），留空则允许所有人
# FEISHU_ALLOW_FROM=ou_xxxx,ou_yyyy

# --- Agent 配置 ---
AGENT_MAX_ITERATIONS=20
AGENT_MEMORY_WINDOW=50
# 工作目录（所有文件相对此目录存放，.xbot/ 下存放 session 和 skills）
# WORK_DIR=.

# --- MCP 会话管理（可选）---
# MCP 不活跃超时时间（默认 30m）
# MCP_INACTIVITY_TIMEOUT=30m
# MCP 清理扫描间隔（默认 5m）
# MCP_CLEANUP_INTERVAL=5m
# 会话缓存超时（默认 24h）
# SESSION_CACHE_TIMEOUT=24h

# --- OAuth 配置 ---
# 启用 OAuth 功能（提供飞书等第三方服务的 OAuth 授权）
OAUTH_ENABLE=false
# OAuth 回调端口（默认 8081，与主业务分离）
# 如果已启用 pprof，可以考虑复用端口或使用不同端口
OAUTH_PORT=8081
# OAuth 回调基础 URL（必须是从公网可访问的 HTTPS 地址）
# 本地开发使用 ngrok: OAUTH_BASE_URL=https://xxxx.ngrok.io
# OAUTH_BASE_URL=https://your-domain.com

# --- 日志配置 ---
LOG_LEVEL=info
LOG_FORMAT=text

# --- 服务器配置 ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
