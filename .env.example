# ============================================================================
# xbot 配置
# 复制此文件为 .env 并填写实际值
# ============================================================================

# --- LLM 配置 ---
# 提供商: "openai" 或 "codebuddy"
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your-api-key
LLM_MODEL=deepseek-chat

# CodeBuddy 专用配置（如果 LLM_PROVIDER=codebuddy）
# LLM_USER_ID=
# LLM_ENTERPRISE_ID=
# LLM_DOMAIN=

# --- 飞书渠道 ---
FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 可选：事件加密和验证
# FEISHU_ENCRYPT_KEY=
# FEISHU_VERIFICATION_TOKEN=
# 可选：允许的用户 open_id 列表（逗号分隔），留空则允许所有人
# FEISHU_ALLOW_FROM=ou_xxxx,ou_yyyy

# --- Agent 配置 ---
AGENT_MAX_ITERATIONS=20
AGENT_MEMORY_WINDOW=50

# --- 日志配置 ---
LOG_LEVEL=info
LOG_FORMAT=text

# --- 服务器配置 ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
