# ============================================================================
# xbot 配置
# 复制此文件为 .env 并填写实际值
# ============================================================================

# --- LLM 配置 ---
# 提供商: "openai" 或 "anthropic"
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-api-key
LLM_MODEL=gpt-4o

# --- LLM 重试配置 ---
# LLM 调用失败时的重试次数（默认 5）
# LLM_RETRY_ATTEMPTS=5
# 初始重试延迟（默认 1s）
# LLM_RETRY_DELAY=1s
# 最大重试延迟（默认 30s）
# LLM_RETRY_MAX_DELAY=30s

# --- 飞书渠道 ---
FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 可选：事件加密和验证
# FEISHU_ENCRYPT_KEY=
# FEISHU_VERIFICATION_TOKEN=
# 可选：允许的用户 open_id 列表（逗号分隔），留空则允许所有人
# FEISHU_ALLOW_FROM=ou_xxxx,ou_yyyy
# 可选：飞书域名（用于生成文档链接等）
# FEISHU_DOMAIN=xxx.feishu.cn

# --- QQ 渠道 ---
QQ_ENABLED=false
QQ_APP_ID=
QQ_CLIENT_SECRET=
# 可选：允许的 openid 列表（逗号分隔），留空则允许所有人
# QQ_ALLOW_FROM=

# --- Agent 配置 ---
AGENT_MAX_ITERATIONS=100
AGENT_MAX_CONCURRENCY=3
AGENT_MEMORY_WINDOW=50
# 工作目录（所有文件相对此目录存放，.xbot/ 下存放 session 和 skills）
# WORK_DIR=.
# 系统提示词模板文件路径（空则使用内置默认值）
# PROMPT_FILE=prompt.md
# 单用户模式：所有消息的 SenderID 归一化为 "default"（默认 false）
# SINGLE_USER=false
# 上下文管理模式（留空则由 EnableAutoCompress 决定）
# AGENT_CONTEXT_MODE=

# --- 上下文压缩 ---
# 是否启用自动上下文压缩（默认 true）
# AGENT_ENABLE_AUTO_COMPRESS=true
# 最大上下文 token 数（默认 100000）
# AGENT_MAX_CONTEXT_TOKENS=100000
# 触发压缩的 token 比例阈值（默认 0.7，即达到 70% 时触发）
# AGENT_COMPRESSION_THRESHOLD=0.7

# --- 话题分区隔离（实验性功能）---
# 启用话题分区隔离（默认 false）
# AGENT_ENABLE_TOPIC_ISOLATION=false
# 最小话题片段大小（默认 3）
# AGENT_TOPIC_MIN_SEGMENT_SIZE=3
# 话题相似度阈值（默认 0.3）
# AGENT_TOPIC_SIMILARITY_THRESHOLD=0.3

# --- SubAgent 配置 ---
# SubAgent 最大嵌套深度（默认 6）
# MAX_SUBAGENT_DEPTH=6
# SubAgent 单次 LLM 调用超时（默认 3m）
# SUBAGENT_LLM_TIMEOUT=3m

# --- 记忆系统 ---
# Letta 模式需要嵌入向量 API（用于归档记忆的语义搜索）
MEMORY_PROVIDER=flat
# 支持任何 OpenAI 兼容的 Embedding API
#
# BASE_URL 必须包含 /v1 路径前缀（统一 OpenAI 兼容接口）
#
# 本地 Ollama 示例（推荐，免费无需 API Key）:
#   ollama pull nomic-embed-text
#   LLM_EMBEDDING_BASE_URL=http://localhost:11434/v1
#   LLM_EMBEDDING_API_KEY=
#   LLM_EMBEDDING_MODEL=nomic-embed-text
#
# OpenAI 示例:
#   LLM_EMBEDDING_BASE_URL=https://api.openai.com/v1
#   LLM_EMBEDDING_API_KEY=sk-xxx
#   LLM_EMBEDDING_MODEL=text-embedding-3-small
#
# Embedding 提供者: "openai" 或 "ollama"
# LLM_EMBEDDING_PROVIDER=
# LLM_EMBEDDING_BASE_URL=
# LLM_EMBEDDING_API_KEY=
# LLM_EMBEDDING_MODEL=
# Embedding 模型最大 token 数，超限时用 LLM 压缩（默认 2048）
# LLM_EMBEDDING_MAX_TOKENS=2048

# --- MCP 会话管理（可选）---
# MCP 不活跃超时时间（默认 30m）
# MCP_INACTIVITY_TIMEOUT=30m
# MCP 清理扫描间隔（默认 5m）
# MCP_CLEANUP_INTERVAL=5m
# 会话缓存超时（默认 24h）
# SESSION_CACHE_TIMEOUT=24h

# --- OAuth 配置 ---
# 启用 OAuth 功能（提供飞书等第三方服务的 OAuth 授权）
OAUTH_ENABLE=false
# OAuth 监听地址（默认 127.0.0.1，仅本地访问）
# OAUTH_HOST=127.0.0.1
# OAuth 回调端口（默认 8081，与主业务分离）
OAUTH_PORT=8081
# OAuth 回调基础 URL（必须是从公网可访问的 HTTPS 地址）
# 本地开发使用 ngrok: OAUTH_BASE_URL=https://xxxx.ngrok.io
# OAUTH_BASE_URL=https://your-domain.com

# --- 沙箱配置 ---
SANDBOX_MODE=docker
# SANDBOX_DOCKER_IMAGE=ubuntu:22.04
# Docker-in-Docker: xbot 在容器内运行时，会自动检测宿主机路径映射。
# 仅在自动检测失败时手动设置（例如使用了自定义 hostname 导致无法自省容器）：
# HOST_WORK_DIR=/home/user
# 用户空闲超时（分钟），超时后自动卸载沙箱，设为 0 禁用（默认 30）
# SANDBOX_IDLE_TIMEOUT_MINUTES=30

# --- 启动通知 ---
# 启动后自动发送上线通知到指定渠道和会话
# STARTUP_NOTIFY_CHANNEL=feishu
# STARTUP_NOTIFY_CHAT_ID=oc_xxxx

# --- 管理员配置 ---
# 管理员会话 ID，用于 Logs 工具等敏感操作权限控制
# 留空则回退到 STARTUP_NOTIFY_CHAT_ID
# ADMIN_CHAT_ID=

# --- Web Search ---
# Tavily API Key（用于 WebSearch 工具）
# TAVILY_API_KEY=tvly-xxxxx

# --- 加密配置 ---
# AES-256-GCM 加密密钥（base64 编码的 32 字节）
# 用于加密存储 API Key 和 OAuth Token，不设置则明文存储
# 生成方式: openssl rand -base64 32
# XBOT_ENCRYPTION_KEY=

# --- PProf 性能分析（可选）---
# PPROF_ENABLE=false
# PPROF_HOST=localhost
# PPROF_PORT=6060

# --- 日志配置 ---
LOG_LEVEL=info
LOG_FORMAT=json

# --- 服务器配置 ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
# HTTP 读超时时间，秒（默认 30）
# SERVER_READ_TIMEOUT=30
# HTTP 写超时时间，秒（默认 120）
# SERVER_WRITE_TIMEOUT=120
